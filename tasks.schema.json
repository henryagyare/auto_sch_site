{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://actionacademy.local/schemas/tasks.schema.json",
    "title": "Action Academy Task Schema",
    "description": "Schema for validating executable task records in tasks.json",
    "type": "array",
    "minItems": 1,
    "items": {
        "$ref": "#/$defs/task"
    },
    "$defs": {
        "task": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "id",
                "title",
                "description",
                "status",
                "priority",
                "owner",
                "dependencies",
                "scope",
                "acceptance_criteria",
                "files_allowed",
                "notes"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^TASK-\\d{3}$",
                    "description": "Unique task identifier, e.g. TASK-001"
                },
                "title": {
                    "type": "string",
                    "minLength": 5,
                    "maxLength": 120
                },
                "description": {
                    "type": "string",
                    "minLength": 10,
                    "maxLength": 1000
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "todo",
                        "in_progress",
                        "blocked",
                        "done",
                        "deferred"
                    ]
                },
                "priority": {
                    "type": "string",
                    "enum": [
                        "low",
                        "medium",
                        "high",
                        "critical"
                    ]
                },
                "owner": {
                    "type": "string",
                    "enum": [
                        "lead",
                        "fullstack",
                        "database",
                        "content",
                        "unassigned"
                    ]
                },
                "dependencies": {
                    "type": "array",
                    "description": "List of prerequisite task IDs that must be completed first",
                    "items": {
                        "type": "string",
                        "pattern": "^TASK-\\d{3}$"
                    },
                    "uniqueItems": true
                },
                "scope": {
                    "type": "string",
                    "enum": [
                        "foundation",
                        "database",
                        "security",
                        "ui",
                        "public-page",
                        "forms",
                        "auth",
                        "admin",
                        "integration",
                        "admin-integration",
                        "quality",
                        "release"
                    ]
                },
                "acceptance_criteria": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "minLength": 5,
                        "maxLength": 300
                    }
                },
                "files_allowed": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 200
                    }
                },
                "files_blocked": {
                    "type": "array",
                    "uniqueItems": true,
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 200
                    }
                },
                "notes": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1000
                },
                "created_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "updated_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "estimated_size": {
                    "type": "string",
                    "enum": [
                        "xs",
                        "s",
                        "m",
                        "l",
                        "xl"
                    ]
                },
                "blocked_reason": {
                    "type": "string",
                    "maxLength": 500
                },
                "parent_backlog_id": {
                    "type": "string",
                    "pattern": "^BL-\\d{3}$"
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "status": {
                                "const": "blocked"
                            }
                        },
                        "required": [
                            "status"
                        ]
                    },
                    "then": {
                        "required": [
                            "blocked_reason"
                        ]
                    }
                }
            ]
        }
    }
}